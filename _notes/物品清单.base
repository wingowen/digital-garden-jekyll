views:
  - type: table
    name: 表格
    filters:
      and:
        - file.inFolder("_notes/物品清单")
    order:
      - file.name
      - file.tags
      - 状态
      - 备注
    sort:
      - property: 状态
        direction: ASC
      - property: file.name
        direction: ASC
  - type: table
    name: 视图
